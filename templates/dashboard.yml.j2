http:
  routers:
    traefik-dashboard:
      rule: "Host(`{{ ansible_role_traefik_with_acme_subdomain }}.{{ ansible_role_traefik_with_acme_domain }}`) && (PathPrefix(`/dashboard`) || PathPrefix(`/api`))"
      entryPoints:
        - websecure
      service: api@internal
      middlewares:
        - dashboard-auth
      tls:
        certResolver: cloudflare

    traefik-root-redirect:
      rule: "Host(`{{ ansible_role_traefik_with_acme_subdomain }}.{{ ansible_role_traefik_with_acme_domain }}`) && Path(`/`)"
      entryPoints:
        - websecure
      service: noop@internal
      middlewares:
        - redirect-to-dashboard
      tls:
        certResolver: cloudflare

  middlewares:
{% if ansible_role_traefik_with_acme_use_authentik %}
    dashboard-auth:
      forwardAuth:
        address: "{{ ansible_role_traefik_with_acme_authentik_url }}"
        trustForwardHeader: true
        authResponseHeaders:
          - X-authentik-username
          - X-authentik-groups
          - X-authentik-email
          - X-authentik-name
          - X-authentik-uid
          - X-authentik-jwt
          - X-authentik-meta-jwks
          - X-authentik-meta-outpost
          - X-authentik-meta-provider
          - X-authentik-meta-app
          - X-authentik-meta-version
{% else %}
    dashboard-auth:
      basicAuth:
        users:
          - "{{ ansible_role_traefik_with_acme_dashboard_users }}"
{% endif %}

    redirect-to-dashboard:
      redirectRegex:
        regex: "^https://{{ ansible_role_traefik_with_acme_subdomain }}\\.{{ ansible_role_traefik_with_acme_domain }}/$"
        replacement: "https://{{ ansible_role_traefik_with_acme_subdomain }}.{{ ansible_role_traefik_with_acme_domain }}/dashboard/"
        permanent: true
