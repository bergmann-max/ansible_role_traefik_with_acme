http:
  routers:
    traefik-dashboard:
      rule: "Host(`{{ traefik_with_acme_fqdn }}`) && (PathPrefix(`/dashboard`) || PathPrefix(`/api`))"
      entryPoints:
        - websecure
      service: api@internal
      middlewares:
        - dashboard-auth
      tls:
        certResolver: cloudflare

    traefik-root-redirect:
      rule: "Host(`{{ traefik_with_acme_fqdn }}`) && Path(`/`)"
      entryPoints:
        - websecure
      service: noop@internal
      middlewares:
        - redirect-to-dashboard
      tls:
        certResolver: cloudflare

{% if traefik_with_acme_use_authentik %}
    traefik-authentik-outpost:
      rule: "Host(`{{ traefik_with_acme_fqdn }}`) && PathPrefix(`/outpost.goauthentik.io/`)"
      entryPoints:
        - websecure
      service: authentik-backend
      tls:
        certResolver: cloudflare
{% endif %}

  middlewares:
{% if traefik_with_acme_use_authentik %}
    dashboard-auth:
      forwardAuth:
        address: "{{ traefik_with_acme_authentik_url }}"
        trustForwardHeader: true
        authResponseHeaders:
          - X-authentik-username
          - X-authentik-groups
          - X-authentik-email
          - X-authentik-name
          - X-authentik-uid
          - X-authentik-jwt
          - X-authentik-meta-jwks
          - X-authentik-meta-outpost
          - X-authentik-meta-provider
          - X-authentik-meta-app
          - X-authentik-meta-version
{% else %}
    dashboard-auth:
      basicAuth:
        users:
          - "{{ traefik_with_acme_dashboard_users }}"
{% endif %}

    redirect-to-dashboard:
      redirectRegex:
        regex: "^https://{{ traefik_with_acme_fqdn }}/$"
        replacement: "https://{{ traefik_with_acme_fqdn }}/dashboard/"
        permanent: true

{% if traefik_with_acme_use_authentik %}
  services:
    authentik-backend:
      loadBalancer:
        servers:
          - url: "{{ traefik_with_acme_authentik_url | urlsplit('scheme') }}://{{ traefik_with_acme_authentik_url | urlsplit('hostname') }}"
        passHostHeader: false
{% endif %}
