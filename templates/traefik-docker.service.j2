[Unit]
Description=Traefik Docker Compose Service
After=network.target docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
User={{ ansible_role_traefik_with_acme_traefik_user }}
Group={{ ansible_role_traefik_with_acme_traefik_group }}
WorkingDirectory={{ ansible_role_traefik_with_acme_docker_compose_dir }}
ExecStart=/usr/bin/docker compose up -d
ExecStop=/usr/bin/docker compose down

[Install]
WantedBy=multi-user.target
